# انسخ هاد الملف لـ .env وعبّي القيم قبل الإطلاق

# مفتاح الجلسات — أنشئه بـ: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here

# Groq API — للمستشار الذكي
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# VAPID للـ Push Notifications
VAPID_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nMH...==\n-----END EC PRIVATE KEY-----
VAPID_EMAIL=mailto:your@email.com

# Anthropic API (اختياري)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Gemini API (اختياري)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxx

# واتساب
WHATSAPP_NUMBER=9613xxxxxxx
